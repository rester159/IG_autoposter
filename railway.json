{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "app/Dockerfile"
  },
  "deploy": {
    "healthcheckPath": "/api/status",
    "healthcheckTimeout": 5,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "requiredMountPath": "/data"
  }
}
